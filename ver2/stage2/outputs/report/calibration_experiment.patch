+def expected_calibration_error(y, prob, n_bins: int = 10) -> float:
+    """Mean |accuracy - confidence| over equal-width probability bins."""
+    bins = np.linspace(0.0, 1.0, n_bins + 1)
+    idx = np.clip(np.digitize(prob, bins) - 1, 0, n_bins - 1)
+    ece = 0.0
+    for b in range(n_bins):
+        mask = idx == b
+        if mask.any():
+            ece += abs(y[mask].mean() - prob[mask].mean()) * mask.mean()
+    return float(ece)
+
